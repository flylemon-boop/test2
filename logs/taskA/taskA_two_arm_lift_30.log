import numpy as np

# First, slightly lift both arms to avoid occlusion
pos0, quat0 = get_arm0_gripper_pose()
pos1, quat1 = get_arm1_gripper_pose()

# Lift arms up by 0.1 meters in Z
lift_offset = np.array([0.0, 0.0, 0.1])
goto_pose_arm0(pos0 + lift_offset, quat0)
goto_pose_arm1(pos1 + lift_offset, quat1)

# Get handle positions from vision
handle0_pos = get_handle0_pos()
handle1_pos = get_handle1_pos()

# Desired grasp orientation: gripper y-axis aligned with world z-axis (sideways grasp)
# Avoid top-down grasp [0, 0, 1, 0]
# Use a sideways grasp where the gripper approaches horizontally
# For arm0 (on one side), we want gripper forward direction along -x, up along z -> results in specific quaternion
# We compute a rotation that aligns gripper's y-axis with world z-axis and forward (-z) along handle radial direction

def look_at_quaternion(forward_direction, up_direction=np.array([0, 0, 1])):
    # Create rotation matrix using forward and up vectors
    forward = -forward_direction / np.linalg.norm(forward_direction)
    right = np.cross(up_direction, forward)
    right /= np.linalg.norm(right)
    up = np.cross(forward, right)
    
    rot_matrix = np.column_stack([right, up, forward])
    
    # Convert rotation matrix to quaternion [w, x, y, z]
    trace = np.trace(rot_matrix)
    if trace > 0:
        s = 0.5 / np.sqrt(trace + 1.0)
        w = 0.25 / s
        x = (rot_matrix[2, 1] - rot_matrix[1, 2]) * s
        y = (rot_matrix[0, 2] - rot_matrix[2, 0]) * s
        z = (rot_matrix[1, 0] - rot_matrix[0, 1]) * s
    else:
        if rot_matrix[0, 0] > rot_matrix[1, 1] and rot_matrix[0, 0] > rot_matrix[2, 2]:
            s = 2.0 * np.sqrt(1.0 + rot_matrix[0, 0] - rot_matrix[1, 1] - rot_matrix[2, 2])
            w = (rot_matrix[2, 1] - rot_matrix[1, 2]) / s
            x = 0.25 * s
            y = (rot_matrix[0, 1] + rot_matrix[1, 0]) / s
            z = (rot_matrix[0, 2] + rot_matrix[2, 0]) / s
        elif rot_matrix[1, 1] > rot_matrix[2, 2]:
            s = 2.0 * np.sqrt(1.0 + rot_matrix[1, 1] - rot_matrix[0, 0] - rot_matrix[2, 2])
            w = (rot_matrix[0, 2] - rot_matrix[2, 0]) / s
            x = (rot_matrix[0, 1] + rot_matrix[1, 0]) / s
            y = 0.25 * s
            z = (rot_matrix[1, 2] + rot_matrix[2, 1]) / s
        else:
            s = 2.0 * np.sqrt(1.0 + rot_matrix[2, 2] - rot_matrix[0, 0] - rot_matrix[1, 1])
            w = (rot_matrix[1, 0] - rot_matrix[0, 1]) / s
            x = (rot_matrix[0, 2] + rot_matrix[2, 0]) / s
            y = (rot_matrix[1, 2] + rot_matrix[2, 1]) / s
            z = 0.25 * s
    
    return np.array([w, x, y, z])

# Compute approach directions for each arm
# Arm0 should approach handle0 from the side (along -x direction relative to pot center)
# Assume handle0 is on the negative x side, handle1 on positive x side
approach_dir0 = handle0_pos - np.array([0, 0, handle0_pos[2]])  # horizontal direction toward handle0
approach_dir1 = handle1_pos - np.array([0, 0, handle1_pos[2]])  # horizontal direction toward handle1

# Normalize horizontal components
approach_dir0[:2] = approach_dir0[:2] / np.linalg.norm(approach_dir0[:2])
approach_dir1[:2] = approach_dir1[:2] / np.linalg.norm(approach_dir1[:2])

# Generate quaternions for both arms
quat_wxyz0 = look_at_quaternion(approach_dir0, np.array([0, 0, 1]))
quat_wxyz1 = look_at_quaternion(approach_dir1, np.array([0, 0, 1]))

# Approach distance in Z for pre-grasp pose
approach_z = 0.05

# Move both arms simultaneously to pre-grasp poses
