pre_grasp_pos1 = handle1_pos + approach_dir1 * 0.1

goto_pose_both(
    position0=pre_grasp_pos0,
    quaternion_wxyz0=quat_wxyz0,
    position1=pre_grasp_pos1,
    quaternion_wxyz1=quat_wxyz1,
    z_approach=approach_z
)

# Open both grippers
open_gripper_arm0()
open_gripper_arm1()

# Now move to grasp poses (with z_approach for precise insertion)
goto_pose_both(
    position0=handle0_pos,
    quaternion_wxyz0=quat_wxyz0,
    position1=handle1_pos,
    quaternion_wxyz1=quat_wxyz1,
    z_approach=approach_z
)

# Close both grippers
close_gripper_arm0()
close_gripper_arm1()

# Lift the pot together to a higher position (e.g., 0.1m above current handle height)
lift_height = 0.1
lift_pos0 = handle0_pos + np.array([0, 0, lift_height])
