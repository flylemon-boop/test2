# Function to create rotation matrix and convert to quaternion for gripper alignment
def vec_to_quat(forward, up):
    # forward: desired z-axis (direction gripper will approach)
    # up: desired y-axis (aligned with world z)
    z_axis = forward / np.linalg.norm(forward)
    y_axis = up / np.linalg.norm(up)
    x_axis = np.cross(y_axis, z_axis)
    y_axis = np.cross(z_axis, x_axis)  # Re-orthogonalize
